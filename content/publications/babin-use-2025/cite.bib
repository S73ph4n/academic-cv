@inproceedings{babin_use_2025,
 abstract = {Diagnosis of microbial bloodstream infections involves two key steps: detection and identification of the pathogen. In clinical laboratories, these two processes are clearly separated, with a culture step (detection) and a mass spectrometry step (identification). A few rare technologies enable coupling, but they are a priori (analysis with a specific probe such as an antibody) or even destructive (PCR), two features that make their implementation problematic.
We propose here a revolutionary method for detecting and identifying bacterial contamination in a complex sample (such as human whole blood) without a priori, manipulation or addition of reagent.
Blood culture bottles were instrumented and sterilized with polyaniline-based (pH sensitive conductive polymer) electrochemical sensors. Over a hundred human blood samples were tested, inoculated with reference bacterial strains. Thanks to potentiometric measurement during culture, we are able not only to detect bacterial growth (without false positives or false negatives), but also to extract an electrochemical signature specific to the microbial species detected. 
We have coupled our instrumented bottle device with a machine learning algorithm to classify these signatures and thus recognize the pathogen directly during culture, without any human intervention. Furthermore, the detection times obtained by our method are comparable to those of current commercial optical transduction systems (Bactec™ and BacT/ALERT®).
It appears that we detect more than just pH changes in PAni-contaminated blood solution. To better understand the nature of our signals, electrochemical impedance spectroscopy characterizations were carried out in an experimental set-up enabling real-time extraction of bacterial metabolites during culture. These results reveal the decisive role played by microbial growth on the electrode surface in creating the electrochemical signatures that ultimately enable identification. Finally, this work suggests that direct electron transfer by bacteria, coupled with the detection of pH variations in PAni, is the electrochemical mechanism responsible for species-dependent dynamics.
This unique new method could significantly reduce the time and cost of diagnosing bloodstream infections. Clinical studies are currently underway to validate the device under real-life conditions.},
 address = {Strasbourg, France},
 author = {Babin, Thibaut and Bernard, Laura and Dedole, Tommy and Bouvet, Pierre and Pissot, Stephan and Marcoux, Pierre and Gougis, Maxime and Mailley, Pascal},
