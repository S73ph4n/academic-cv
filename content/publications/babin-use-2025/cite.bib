 file = {HAL PDF Full Text:/home/ua7/snap/zotero-snap/common/Zotero/storage/DXE6PMAT/Babin et al. - 2025 - Use of polyaniline (PAni) for the detection and identification of bacteria in human whole blood by e.pdf:application/pdf},
 month = {May},
 title = {Use of polyaniline (PAni) for the detection and identification of bacteria in human whole blood by electrochemistry},
